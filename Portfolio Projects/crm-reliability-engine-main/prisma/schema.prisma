generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum EntityType {
  Contact
  Opportunity
}

enum MutationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Contact {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  title        String?
  company_size String?
  status       String   @default("ACTIVE")
}

model Opportunity {
  id               Int      @id @default(autoincrement())
  name             String
  amount           Float
  stage            String
  closeDate        DateTime
  nextStep         String?
  riskScore        Float    @default(0.0)
  isStale          Boolean  @default(false)
  lastActivityDate DateTime @default(now())
}

model SuggestedMutation {
  id              Int            @id @default(autoincrement())
  entityType      EntityType
  entityId        Int
  proposedChange  String         // JSON string of proposed fields
  confidenceScore Float
  reasoning       String         @default("[]") // JSON array of reasoning strings
  status          MutationStatus @default(PENDING)
  createdAt       DateTime       @default(now())
}

model Event {
  id         Int        @id @default(autoincrement())
  entityType EntityType
  entityId   Int
  eventType  String     // e.g. MUTATION_APPROVED, EXTRACTION_SUGGESTED
  payload    String     // JSON string of the event details
  timestamp  DateTime   @default(now())
}
